{
  "name": "noisetoy",
  "version": "0.0.4",
  "description": "Noise functions with TypeScript, GLSL, WGSL and Three.js TSL parity, plus a layer compositor that emits any of them",
  "keywords": [
    "glsl",
    "noise",
    "perlin",
    "procedural",
    "simplex",
    "texture",
    "threejs",
    "tsl",
    "webgl",
    "webgpu",
    "wgsl",
    "worley"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/verekia/noisetoy.git",
    "directory": "library"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./three": {
      "types": "./dist/three.d.ts",
      "import": "./dist/three.js"
    },
    "./implementations": {
      "types": "./dist/implementations.d.ts",
      "import": "./dist/implementations.js"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup && cp ../README.md README.md",
    "typecheck": "tsc --noEmit",
    "bench:impl": "bun run src/alt/bench.ts"
  },
  "devDependencies": {
    "@types/bun": "1.3.9",
    "@types/three": "0.183.1",
    "@webgpu/types": "0.1.69",
    "three": "0.183.2",
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "three": ">=0.170"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  }
}
