{
  "name": "noisetoy",
  "version": "0.0.4",
  "description": "Tree-shakeable noise functions with TypeScript, GLSL, WGSL and Three.js TSL parity — import exactly the variants you ship",
  "keywords": [
    "glsl",
    "noise",
    "perlin",
    "procedural",
    "simplex",
    "texture",
    "threejs",
    "tsl",
    "webgl",
    "webgpu",
    "wgsl",
    "worley"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/verekia/noisetoy.git",
    "directory": "library"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsc -p tsconfig.build.json --watch",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && cp ../README.md README.md",
    "typecheck": "tsc --noEmit",
    "bench:impl": "bun run src/alt/bench.ts"
  },
  "devDependencies": {
    "@types/bun": "1.3.9",
    "@types/three": "0.183.1",
    "@webgpu/types": "0.1.69",
    "three": "0.183.2",
    "typescript": "6.0.3"
  }
}
